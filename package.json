{
  "name": "dub-siren",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "clean:ios-iconset": "rm -f ios/*/Images.xcassets/AppIcon.appiconset/*.png && npx expo prebuild --platform ios --no-install",
    "postinstall": "patch-package && node scripts/patch-spotify-podspec.js && node scripts/strip-spotify-bitcode.js && node scripts/ensure-rn-audio-api-binaries.js",
    "deploy-landing": "gh-pages -d landing -b gh-pages"
  },
  "dependencies": {
    "@fkeulen/react-native-spotify-remote": "^0.3.11-5",
    "expo": "~54.0.33",
    "expo-asset": "^55.0.8",
    "expo-haptics": "~15.0.8",
    "expo-linear-gradient": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-audio-api": "^0.11.5",
    "react-native-gesture-handler": "~2.28.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "gh-pages": "^6.1.1",
    "patch-package": "^8.0.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
